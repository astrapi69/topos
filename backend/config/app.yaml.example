# Topos application config. Copy this file to ``app.yaml`` on first
# run; the backend creates it automatically on startup if absent.
#
# Configuration layers (highest priority wins):
#
# 1. Environment variables (``TOPOS_*``)
# 2. User secrets override (~/.config/topos/secrets.yaml)
# 3. User overlay file (<data_dir>/config/app.yaml)
# 4. This file (project defaults)

app:
  default_language: de
  description: Personal inventory tracker
  name: Topos
  supported_languages:
    - de
    - en
    - es
    - fr
    - el
    - pt
    - tr
    - ja
  # Defense-in-depth body-size cap enforced by
  # BodySizeLimitMiddleware. Applies to every POST / PUT / PATCH
  # request. Editing requires a server restart.
  max_upload_mb: 500

plugins:
  config_dir: config/plugins
  disabled: []
  enabled:
    - excel_import
  entry_point_group: topos.plugins

licensing:
  # INTERNAL: secret for HMAC signing of premium license keys.
  # Override via ``TOPOS_SECRET_KEY`` env-var in production.
  secret_key: pluginforge-default-key
  store_path: config/licenses.json

ui:
  theme: classic
  title: Topos

ai:
  # AI provider configuration for image recognition of box contents.
  # API keys are NEVER stored in this committed file - they live in
  # ~/.config/topos/secrets.yaml or the TOPOS_*_API_KEY env vars and
  # are merged in at runtime. The empty ``keys`` placeholders below
  # only document the shape; the Settings UI writes resolved values to
  # the user-overlay app.yaml, not here.
  enabled: false
  active_provider: anthropic
  # Selected model per provider. Defaults are vision-capable because
  # the headline feature is recognising items from a photo. See
  # GET /api/settings/ai/providers for the suggested vision models.
  models:
    anthropic: claude-sonnet-4-6
    openai: gpt-4o-mini
    google: gemini-2.0-flash
    custom: ""
  # base_url override for the ``custom`` (OpenAI-compatible) provider,
  # e.g. a local Ollama instance at http://localhost:11434/v1.
  base_urls:
    custom: ""
  # API keys per provider. Leave empty here; set via secrets.yaml or
  # env. The Settings UI edits these only when not externally managed.
  keys:
    anthropic: ""
    openai: ""
    google: ""
    custom: ""
