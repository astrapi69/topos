# Topos application config. Copy this file to ``app.yaml`` on first
# run; the backend creates it automatically on startup if absent.
#
# Configuration layers (highest priority wins):
#
# 1. Environment variables (``TOPOS_*``)
# 2. User secrets override (~/.config/topos/secrets.yaml)
# 3. User overlay file (<data_dir>/config/app.yaml)
# 4. This file (project defaults)

app:
  default_language: de
  description: Personal inventory tracker
  name: Topos
  supported_languages:
    - de
    - en
    - es
    - fr
    - el
    - pt
    - tr
    - ja
  # Defense-in-depth body-size cap enforced by
  # BodySizeLimitMiddleware. Applies to every POST / PUT / PATCH
  # request. Editing requires a server restart.
  max_upload_mb: 500

plugins:
  config_dir: config/plugins
  disabled: []
  enabled: []
  entry_point_group: topos.plugins

licensing:
  # INTERNAL: secret for HMAC signing of premium license keys.
  # Override via ``TOPOS_SECRET_KEY`` env-var in production.
  secret_key: pluginforge-default-key
  store_path: config/licenses.json

ui:
  theme: classic
  title: Topos
