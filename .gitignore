# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
.venv/
venv/

# Mutation testing
mutants/
mutmut-stats.json

# Launcher build-time artifact (generated by PyInstaller spec from
# backend/pyproject.toml, see launcher/topos-launcher.spec).
launcher/topos_launcher/_build_info.py

# Coverage (generated by `make test-coverage` or CI)
.coverage
.coverage.*
htmlcov/
coverage.xml
frontend/coverage/

# Environment
.env

# Encrypted credentials (service account keys etc.)
backend/config/plugins/audiobook/google-credentials.enc

# Database
*.db
*.db-shm
*.db-wal
*.db-journal

# Uploads (user assets)
backend/uploads/
backend/*.migrated-*

# Production marker (written by FastAPI lifespan startup; see
# backend/app/paths.py + backend/tests/conftest.py).
.topos-production

# MkDocs build output
site/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Docker
topos-data/

# Node (frontend)
node_modules/
build/
.next/
frontend/dev-dist/
*.tsbuildinfo

# Temp export files
/tmp/topos_*

# Dev PID files
.pid-backend
.pid-frontend

# Config files
/backend/config/backup_history.json
/backend/config/licenses.json
/backend/config/app.yaml

# prompt files
/tmp/todo-prompts.md

# Playwright results
/e2e/test-results/
/e2e/playwright-report/
tmp/

# Claude Code runtime artifacts (per-session lock + scheduled-task state).
# Pre-commit's end-of-file-fixer would otherwise endlessly modify the
# lock file, turning CI red on every push.
/.claude/scheduled_tasks.lock
/.agents/*
